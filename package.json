{
  "name": "bashterm-mcp-server",
  "displayName": "BashTerm MCP",
  "description": "MCP server that executes commands in visible VSCode terminal tabs. Supports Windows, macOS and Linux.",
  "version": "0.3.0",
  "publisher": "hcdb",
  "license": "MIT",
  "author": "hcdb",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1170953489/bashterm-mcp.git"
  },
  "homepage": "https://github.com/1170953489/bashterm-mcp#readme",
  "bugs": {
    "url": "https://github.com/1170953489/bashterm-mcp/issues"
  },
  "keywords": [
    "mcp",
    "terminal",
    "vscode",
    "claude",
    "claude-code",
    "model-context-protocol",
    "ai-tools"
  ],
  "mcpName": "io.github.hcdb/bashterm-mcp-server",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:bashterm-mcp-server.restoreClaudeCodeDefaultBash"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "bashterm-mcp-server": "dist/mcp-entry.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "bashterm-mcp-server.restoreClaudeCodeDefaultBash",
        "title": "BashTerm MCP: Restore Claude Code Default Bash"
      }
    ],
    "mcpServers": {
      "bashterm-mcp-server": {
        "type": "stdio",
        "command": "node",
        "args": [
          "${extensionPath}/dist/mcp-entry.js"
        ]
      }
    },
    "configuration": {
      "title": "BashTerm MCP",
      "properties": {
        "bashterm-mcp-server.autoConfigureClaudeCode": {
          "type": "boolean",
          "default": true,
          "description": "Automatically configure Claude Code to keep simple built-in Bash commands allowed while redirecting complex Bash commands to BashTerm MCP tools"
        },
        "bashterm-mcp-server.blockedCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "rm -rf /",
            "mkfs",
            "dd if=",
            ":(){ :|:& };:"
          ],
          "description": "Commands that are never allowed to execute"
        },
        "bashterm-mcp-server.allowedDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Allowed working directories (empty = unrestricted)"
        },
        "bashterm-mcp-server.windowsDefaultShell": {
          "type": "string",
          "enum": [
            "vscode",
            "cmd",
            "powershell",
            "pwsh"
          ],
          "default": "vscode",
          "description": "Default shell for Windows when no shell is explicitly requested and command detection is inconclusive. 'vscode' uses the user's configured VSCode terminal profile."
        },
        "bashterm-mcp-server.windowsShellDetection": {
          "type": "boolean",
          "default": true,
          "description": "Automatically route high-confidence Windows commands to cmd or PowerShell for the run tool. Existing sessions used by exec are never switched automatically."
        },
        "bashterm-mcp-server.defaultTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "Default timeout for command execution in milliseconds"
        },
        "bashterm-mcp-server.maxConcurrentSessions": {
          "type": "number",
          "default": 10,
          "description": "Maximum number of concurrent terminal sessions"
        },
        "bashterm-mcp-server.maxOutputLines": {
          "type": "number",
          "default": 10000,
          "description": "Maximum number of output lines to buffer per session"
        },
        "bashterm-mcp-server.idleTimeoutMs": {
          "type": "number",
          "default": 300000,
          "description": "Auto-close idle sessions after this many milliseconds (0 = disabled)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "strip-ansi": "^7.1.0",
    "uuid": "^9.0.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.0",
    "@types/vscode": "^1.99.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^2.26.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
